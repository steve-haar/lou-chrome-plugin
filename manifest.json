{
  "manifest_version": 3,
  "name": "Lou Barcode Generator",
  "version": "1.0.0",
  "description": "Adds a Print Label button to Lou (Evosus) SKU pages that generates a scannable barcode label.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://lou.evosus.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://lou.evosus.com/*"],
      "js": ["lib/JsBarcode.all.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/JsBarcode.all.min.js"],
      "matches": ["https://lou.evosus.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
